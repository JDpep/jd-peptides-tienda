{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn app:app --worker-class=gevent --workers=2 --worker-connections=100 --timeout=0 --keep-alive=5 --max-requests=500 --max-requests-jitter=50",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
